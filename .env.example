# Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Admin
ADMIN_PASSWORD="changeme"
# Vercel Blob read/write token (set automatically after Blob storage integration on Vercel)
BLOB_READ_WRITE_TOKEN=""

# Runtime DB init (optional, production safety gate)
RUNTIME_DB_INIT_ENABLED="false"
RUNTIME_DB_INIT_ON_FIRST_REQUEST="false"
RUNTIME_DB_INIT_ALLOW_SEED="false"
INIT_DB_TOKEN="replace-with-long-random-token"
